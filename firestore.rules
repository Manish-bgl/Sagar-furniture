rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      // ✅ Anyone can view the catalog (public read)
      allow read: if true;
      
      // 🔒 Only logged in administrators/managers can add, edit or delete products
      allow write: if request.auth != null;
    }
  }
}
